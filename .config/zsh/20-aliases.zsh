alias l="ls -alh"
alias c="clear"
alias vim="nvim"
alias vi="nvim"
alias tm="tmux"
alias venv="source .venv/bin/activate"
alias lg="lazygit"
alias bopen="open -a 'Brave Browser'"
alias ol="printf 'light' > ~/.tmux_theme; tmux source-file ~/.config/tmux/themes/light.conf; tmux set-environment -g THEME 'light'"
alias od="printf 'dark' > ~/.tmux_theme; tmux source-file ~/.config/tmux/themes/dark.conf; tmux set-environment -g THEME 'dark'"
alias sd="cd ~ && cd \$(find * -type d | fzf --height 40% --reverse)"
